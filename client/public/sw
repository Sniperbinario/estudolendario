// Service Worker — EstudoLendário
// Gerencia push notifications e cache básico

self.addEventListener("install", e => {
  self.skipWaiting();
});

self.addEventListener("activate", e => {
  e.waitUntil(clients.claim());
});

// Recebe push notification do servidor (ou da própria página via showNotification)
self.addEventListener("push", e => {
  const data = e.data ? e.data.json() : {};
  const title = data.title || "EstudoLendário 📚";
  const options = {
    body: data.body || "Você tem tarefas para hoje!",
    icon: "/distintivo.png",
    badge: "/distintivo.png",
    tag: data.tag || "estudolendario",
    renotify: true,
    data: { url: data.url || "/" },
    actions: [
      { action: "abrir", title: "📚 Estudar agora" },
      { action: "fechar", title: "Depois" },
    ],
  };
  e.waitUntil(self.registration.showNotification(title, options));
});

// Clique na notificação
self.addEventListener("notificationclick", e => {
  e.notification.close();
  if (e.action === "fechar") return;
  e.waitUntil(
    clients.matchAll({ type: "window", includeUncontrolled: true }).then(clientList => {
      for (const client of clientList) {
        if (client.url.includes(self.location.origin) && "focus" in client) {
          return client.focus();
        }
      }
      if (clients.openWindow) return clients.openWindow("/");
    })
  );
});
